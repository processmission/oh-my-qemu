---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
const link = (path: string) => `${base}${path.replace(/^\//, "")}`;
const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 1);
const docs = (await getCollection("docs")).sort((a, b) => a.data.order - b.data.order).slice(0, 4);
const formatDate = (date: Date) => new Intl.DateTimeFormat("en", { month: "short", day: "numeric", year: "numeric" }).format(date);
---
<BaseLayout title="Oh My QEMU" description="Portable, auditable skills for local QEMU work." section="home">
  <section class="hero section" aria-labelledby="hero-title">
    <div class="hero-copy">
      <p class="eyebrow">17 portable skills · Local QEMU work</p>
      <h1 id="hero-title">Auditable QEMU workflows, installed per project.</h1>
      <p class="hero-lede">
        Install only the skills you need, keep task evidence in one local
        workspace, and isolate every QEMU build by target.
      </p>
      <div class="hero-actions">
        <a class="button primary" href={link("docs/getting-started/")}>Get started</a>
        <a class="button secondary" href={link("docs/skills/")}>Browse skills</a>
      </div>
    </div>
    <aside class="hero-panel" aria-label="Workflow snapshot">
      <div class="terminal-card">
        <div class="terminal-bar" aria-hidden="true"><span></span><span></span><span></span></div>
        <pre><code># Run from the QEMU source root
curl -fsSL https://raw.githubusercontent.com/processmission/oh-my-qemu/main/install.sh | bash

audit → .oh-my-qemu/k230-uart/
QEMU  → builds/build-aarch64/</code></pre>
      </div>
    </aside>
  </section>

  <section class="section intro" aria-labelledby="overview-title">
    <div class="section-heading">
      <p class="eyebrow">Overview</p>
      <h2 id="overview-title">A small, portable layer for QEMU work.</h2>
      <p>Each skill works alone and carries the same audit and workspace rules.</p>
    </div>
    <div class="feature-grid">
      <article class="feature-card">
        <h3>Install per project</h3>
        <p>Use one curl command to install all 17 skills into project-local Codex and Claude Code, then set up the repository's local Git excludes.</p>
      </article>
      <article class="feature-card">
        <h3>Keep an audit trail</h3>
        <p>Decisions, commands, logs, temporary scripts, and generated output stay under <code>.oh-my-qemu/&lt;task-slug&gt;/</code>.</p>
      </article>
      <article class="feature-card">
        <h3>Separate QEMU builds</h3>
        <p>Configure QEMU only in named directories such as <code>builds/build-aarch64/</code>, one target or configuration per directory.</p>
      </article>
    </div>
  </section>


  {posts.length > 0 && (
    <section class="section blog" id="blog" aria-labelledby="blog-title">
      <div class="section-heading split">
        <div>
          <p class="eyebrow">Blog</p>
          <h2 id="blog-title">Latest note.</h2>
        </div>
        <a class="text-link" href={link("blog/")}>All posts</a>
      </div>
      <div class="post-grid single">
        {posts.map((post) => (
          <article class="post-card">
            <p class="post-meta">{formatDate(post.data.pubDate)} · {post.data.tags.join(", ")}</p>
            <h3><a href={link(`blog/${post.id}/`)}>{post.data.title}</a></h3>
            <p>{post.data.description}</p>
          </article>
        ))}
      </div>
    </section>
  )}

  <section class="section docs" id="docs" aria-labelledby="docs-title">
    <div class="section-heading split">
      <div>
        <p class="eyebrow">Docs</p>
        <h2 id="docs-title">Documentation.</h2>
      </div>
      <a class="text-link" href={link("docs/")}>All docs</a>
    </div>
    <div class="docs-layout">
      {docs.map((doc, index) => (
        <article class="doc-card">
          <span class="doc-index">{String(index + 1).padStart(2, "0")}</span>
          <h3>{doc.data.title}</h3>
          <p>{doc.data.description}</p>
          <a href={link(`docs/${doc.id}/`)}>Read guide</a>
        </article>
      ))}
    </div>
  </section>

</BaseLayout>
