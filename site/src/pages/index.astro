---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
const link = (path: string) => `${base}${path.replace(/^\//, "")}`;
const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 1);
const docs = (await getCollection("docs")).sort((a, b) => a.data.order - b.data.order).slice(0, 4);
const formatDate = (date: Date) => new Intl.DateTimeFormat("en", { month: "short", day: "numeric", year: "numeric" }).format(date);
---
<BaseLayout title="Oh My QEMU" description="Evidence-first QEMU agent workflows, blog posts, and documentation." section="home">
  <section class="hero section" aria-labelledby="hero-title">
    <div class="hero-copy">
      <p class="eyebrow">Official site · Blog · Documentation</p>
      <h1 id="hero-title">Evidence-first QEMU modeling for coding agents.</h1>
      <p class="hero-lede">
        Notes and documentation for QEMU agent workflows: provenance, evidence,
        local checkpoints, and clean final handoffs.
      </p>
      <div class="hero-actions">
        <a class="button primary" href={link("blog/")}>Read the blog</a>
        <a class="button secondary" href={link("docs/")}>Open docs</a>
      </div>
    </div>
    <aside class="hero-panel" aria-label="Workflow snapshot">
      <div class="terminal-card">
        <div class="terminal-bar" aria-hidden="true"><span></span><span></span><span></span></div>
        <pre><code>/qemu-workflow Model the K230 UART and prove it with qtest.

plan → provenance → register extraction
model → qtest → review → local checkpoint
final-series drafts → evidence summary</code></pre>
      </div>
    </aside>
  </section>

  <section class="section intro" aria-labelledby="overview-title">
    <div class="section-heading">
      <p class="eyebrow">Overview</p>
      <h2 id="overview-title">A small workflow layer for QEMU work.</h2>
      <p>Use it when you need reproducible research, targeted verification, and a clean handoff.</p>
    </div>
    <div class="feature-grid">
      <article class="feature-card">
        <h3>Model from hardware facts</h3>
        <p>Extract register maps, side effects, IRQ flows, boot paths, and driver sequences before changing device code.</p>
      </article>
      <article class="feature-card">
        <h3>Keep source trees clean</h3>
        <p>Plans, logs, probes, traces, and reviews stay under the task artifact root instead of the QEMU source root.</p>
      </article>
      <article class="feature-card">
        <h3>Verify before moving on</h3>
        <p>Each slice records targeted build, qtest, boot, debug, or documentation evidence before review.</p>
      </article>
    </div>
  </section>


  {posts.length > 0 && (
    <section class="section blog" id="blog" aria-labelledby="blog-title">
      <div class="section-heading split">
        <div>
          <p class="eyebrow">Blog</p>
          <h2 id="blog-title">Latest note.</h2>
        </div>
        <a class="text-link" href={link("blog/")}>All posts</a>
      </div>
      <div class="post-grid single">
        {posts.map((post) => (
          <article class="post-card">
            <p class="post-meta">{formatDate(post.data.pubDate)} · {post.data.tags.join(", ")}</p>
            <h3><a href={link(`blog/${post.id}/`)}>{post.data.title}</a></h3>
            <p>{post.data.description}</p>
          </article>
        ))}
      </div>
    </section>
  )}

  <section class="section docs" id="docs" aria-labelledby="docs-title">
    <div class="section-heading split">
      <div>
        <p class="eyebrow">Docs</p>
        <h2 id="docs-title">Documentation.</h2>
      </div>
      <a class="text-link" href={link("docs/")}>All docs</a>
    </div>
    <div class="docs-layout">
      {docs.map((doc, index) => (
        <article class="doc-card">
          <span class="doc-index">{String(index + 1).padStart(2, "0")}</span>
          <h3>{doc.data.title}</h3>
          <p>{doc.data.description}</p>
          <a href={link(`docs/${doc.id}/`)}>Read guide</a>
        </article>
      ))}
    </div>
  </section>

</BaseLayout>
