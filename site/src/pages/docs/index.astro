---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
const link = (path: string) => `${base}${path.replace(/^\//, "")}`;
const docs = (await getCollection("docs")).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Documentation" description="Install Oh My QEMU skills, browse the catalog, and apply the audit and build policy." section="docs">
  <section class="section page-hero">
    <p class="eyebrow">Documentation</p>
    <h1>Portable skills with one audit contract.</h1>
    <p>Project-local installation, the 17-skill catalog, and workspace rules for local QEMU work.</p>
  </section>

  <section class="section listing" aria-label="Documentation pages">
    <div class="docs-layout">
      {docs.map((doc, index) => (
        <article class="doc-card">
          <span class="doc-index">{String(index + 1).padStart(2, "0")}</span>
          <p class="post-meta">{doc.data.category}</p>
          <h2>{doc.data.title}</h2>
          <p>{doc.data.description}</p>
          <a href={link(`docs/${doc.id}/`)}>Read guide</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
