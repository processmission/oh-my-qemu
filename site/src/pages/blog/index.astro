---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
const link = (path: string) => `${base}${path.replace(/^\//, "")}`;
const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const formatDate = (date: Date) => new Intl.DateTimeFormat("en", { month: "short", day: "numeric", year: "numeric" }).format(date);
---

<BaseLayout title="Blog" description="Oh My QEMU blog posts about QEMU modeling workflows, provenance, verification, and release notes." section="blog">
  <section class="section page-hero">
    <p class="eyebrow">Blog</p>
    <h1>Field notes for evidence-first QEMU work.</h1>
    <p>Release notes, methodology write-ups, modeling guides, and lessons from boot/debug/qtest workflows.</p>
  </section>

  <section class="section listing" aria-label="Blog posts">
    {posts.length > 0 ? (
      <div class="post-grid">
        {posts.map((post) => (
          <article class="post-card">
            <p class="post-meta">{formatDate(post.data.pubDate)} · {post.data.tags.join(", ")}</p>
            <h2><a href={link(`blog/${post.id}/`)}>{post.data.title}</a></h2>
            <p>{post.data.description}</p>
          </article>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <p class="eyebrow">No posts yet</p>
        <h2>Blog posts will live here.</h2>
        <p>Keep this page empty until the first real Oh My QEMU note is ready.</p>
      </div>
    )}
  </section>
</BaseLayout>
